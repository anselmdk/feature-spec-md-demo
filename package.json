{
  "name": "feature-spec-md-demo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "spec:check": "feature-spec-md check",
    "spec:coverage": "feature-spec-md coverage",
    "spec:report": "feature-spec-md report",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "rm -rf test-results/spec-report && playwright test",
    "verify": "npm run build && npm run spec:check && npm run spec:coverage && npm run test:unit && npm run test:e2e && npm run spec:report",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anselmdk/feature-spec-md": "0.7.0-rc.3",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "prettier": "^3.8.4",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
