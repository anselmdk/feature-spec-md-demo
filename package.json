{
  "name": "feature-spec-md-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "feature-spec-md": "node scripts/feature-spec-md.mjs",
    "spec:check": "npm run feature-spec-md -- check --specs \"specs/**/*.feature.md\" --tests \"tests/**/*.ts\" --require-rule-coverage",
    "spec:report": "npm run feature-spec-md -- report --specs \"specs/**/*.feature.md\" --tests \"tests/**/*.ts\" --screenshots \"test-results/spec-report/screenshots-*.json\" --out test-results/spec-report/index.html",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "node scripts/clean-spec-report.mjs && playwright test",
    "verify": "npm run spec:check && npm run test:unit && npm run test:e2e && npm run spec:report",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anselmdk/feature-spec-md": "^0.1.1",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "prettier": "^3.8.4",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
