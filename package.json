{
  "name": "feature-spec-md-demo",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite -host 127.0.0.1",
    "build": "tsc -b && vite build",
    "spec:check": "feature-spec-md check --tests \"tests/**/*.ts\" --require-rule-coverage --require-model-coverage",
    "spec:coverage": "feature-spec-md coverage --tests \"tests/**/*.ts\" --fail-on-missing",
    "spec:report": "feature-spec-md report --tests \"tests/**/*.ts\" --screenshots \"test-results/spec-report/screenshots-*.json\" --enforce-evidence --out test-results/spec-report/index.html",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "node scripts/clean-spec-report.mjs && playwright test",
    "verify": "npm run build && npm run spec:check && npm run spec:coverage && npm run test:unit && npm run test:e2e && npm run spec:report",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@anselmdk/feature-spec-md": "0.5.0-rc.2",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "prettier": "^3.8.4",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
